# =============================================================================
# Canonical CUDA slot → package version matrix
#
# This is the single source of truth for version compatibility.
# Shell-sourceable key=value format; sourced by docker/scripts/*.sh.
#
# When bumping a version:
#   1. Update the version here.
#   2. Update the matching conda YAML in docker/envs/.
#   3. Rebuild: ./docker/scripts/build-env.sh <slot>
#
# Verify versions against the official compatibility tables:
#   PyTorch:     https://pytorch.org/get-started/previous-versions/
#   TensorFlow:  https://www.tensorflow.org/install/source#gpu
# =============================================================================

# ── Base NVIDIA images ────────────────────────────────────────────────────────
CUDA_IMAGE_118="nvidia/cuda:11.8.0-devel-ubuntu22.04"
CUDA_IMAGE_121="nvidia/cuda:12.1.1-devel-ubuntu22.04"
CUDA_IMAGE_124="nvidia/cuda:12.4.1-devel-ubuntu22.04"
CUDA_IMAGE_126="nvidia/cuda:12.6.2-devel-ubuntu22.04"
CUDA_IMAGE_130="nvidia/cuda:13.0.2-devel-ubuntu24.04"

# ── PyTorch slots ─────────────────────────────────────────────────────────────
# Triton is a transitive pip dependency of torch; version is implicit.
CUDA_118_TORCH="2.1.0"
CUDA_118_TORCH_TRITON="2.1.0"   # ships with torch 2.1.x

CUDA_121_TORCH="2.2.1"
CUDA_121_TORCH_TRITON="2.2.1"   # ships with torch 2.2.x

CUDA_124_TORCH="2.6.0"
CUDA_124_TORCH_TRITON="3.2.0"   # ships with torch 2.6.x

CUDA_126_TORCH="2.6.0"
CUDA_126_TORCH_TRITON="3.2.0"   # ships with torch 2.6.x

CUDA_130_TORCH="2.10.0"
CUDA_130_TORCH_TRITON="3.6.0"   # ships with torch 2.10.x

# ── TensorFlow slots ──────────────────────────────────────────────────────────
# tensorflow[and-cuda] bundles its own CUDA/cuDNN runtime; no separate install.
CUDA_124_TF="2.15.0"

# ── Default slot (used by scripts when no slot argument is given) ─────────────
DEFAULT_SLOT="cuda124-torch"
