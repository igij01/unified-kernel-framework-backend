# docker/.env — local overrides for Docker Compose variables
#
# Copy this file to docker/.env and edit as needed.
# docker/.env is gitignored and never committed.
#
# Docker Compose automatically loads docker/.env when you run
# `docker compose -f docker/docker-compose.yml ...`

# ── Jupyter ───────────────────────────────────────────────────────────────────
# Shared token for all Jupyter services.
# Default: "playground"
# JUPYTER_TOKEN=playground

# Per-slot host ports for Jupyter Lab.
# Defaults are spread across 8818– to allow running multiple servers
# simultaneously without port conflicts.
# JUPYTER_PORT_CUDA118=8818
# JUPYTER_PORT_CUDA121=8821
# JUPYTER_PORT_CUDA124=8824
# JUPYTER_PORT_CUDA124TF=8825
# JUPYTER_PORT_CUDA126=8826
# JUPYTER_PORT_CUDA130=8827

# ── WSL2 / Windows path tips ──────────────────────────────────────────────────
# If you want the HuggingFace cache on a Windows drive (e.g. D:\hf_cache),
# you cannot override it directly here because hf-cache is a named Docker
# volume. To redirect it, remove the named volume and add a bind mount to
# docker-compose.yml pointing at /mnt/d/hf_cache.
#
# Alternatively, copy models into the named volume once:
#   docker run --rm -v hf-cache:/cache \
#     -v /mnt/d/hf_cache:/src alpine cp -r /src/. /cache/
